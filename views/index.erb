<!DOCTYPE html>
<html>
<head>
  <title>DUPLICATE MAC CHECKER</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #f8fafc;
    }

    h1 {
      margin-top: 20px;
      text-shadow: 0 0 3px #00000;
    }

    .top-bar {
      position: relative;
      width: 1000px;
      margin: 20px auto;
      height: 70px;
    }

    .top-bar h1 {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        margin: 0;
        font-size: 48px;
        font-weight: bold;
        white-space: nowrap;
    }
    
    .name-field {
        position: absolute;
        right: -200px;
        top: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    input {
      padding: 14px;
      font-size: 24px;
      border-radius: 8px;
      border: 2px solid #d1d5db;
    }

    #result {
      margin-top: 40px;
      font-size: 60px;
      font-weight: bold;
      padding: 40px;
      border-radius: 10px;
    }

    .good {
      background: #34c759;
      color: black;
    }

    .bad {
      background: #ff3b30;
      color: black;
    }

    #last-scan {
      font-size: 50px;
      margin-top: 25px;
      font-weight: bold;
    }

    #result {
      width: 1000px;
      display: grid;
      margin: 0 auto;
      margin-top: 30px;
      border: 2px solid #d1d5db;
      border-radius: 8px;
    }

    #separator {
      width: 1000px;
      height: 2px;
      background-color: #999;
      margin: 20px auto;
    }

    .scan-fields {
      display: flex;
      flex-direction: column;
      gap: 12px;
      width: 400px;
      margin: 0 auto;
    }

    .scan-fields input {
      height: 50px;
      font-size: 24px;
      padding: 10px;
    }

    .buttons {
      position: absolute;
      left: -200px;
      top: 8px;
      display: flex;
      flex-direction: column;  
      align-items: flex-start; 
      gap: 6px;   
    }

    .pending {
      background: #facc15;
      color: black;
    }

    .help-tooltip {
      position: absolute;
      left: 20px;
      top: 20px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      color: #2563eb;
    }

    .tooltip-text {
      visibility: hidden;
      opacity: 0;
      width: 320px;
      background: #111827;
      color: white;
      text-align: left;
      padding: 12px;
      border-radius: 8px;

      position: absolute;
      top: 30px;
      left: 0;
      z-index: 999;

      transition: opacity 0.2s ease;
      font-size: 15px;
      line-height: 1.4;
    }

    .help-tooltip:hover .tooltip-text {
      visibility: visible;
      opacity: 1;
    }

      </style>
    </head>
  <body>

  <audio id="successSound" src="/sounds/success-chime.mp3" preload="auto"></audio>
  <audio id="errorSound" src="/sounds/warning.mp3" preload="auto"></audio>
  <audio id="successSuccessSound" src="/sounds/success_success.mp3" preload="auto"></audio>

  <div class="top-bar">
    <div class="buttons">
      <div class="double-single-toggle"> 
        <label style="font-size: 22px; font-weight: bold; align-content: left">
          <input type="checkbox" id="doubleModeToggle" />
          Double Scan Mode
        </label>
      </div>
      <div class="validation-toggle">
        <label style="font-size: 22px; font-weight: bold; align-content: left">
          <input type="checkbox" id="validationModeToggle" />
          Validation Mode
        </label>
      </div>
    </div>  
    <h1>DUPLICATE MAC CHECKER</h1>

    <div class="name-field">
      <div style="font-weight:bold; font-size:20px">Worker Name</div>
      <input id="workerName" placeholder="Enter your name" style="font-size:20px; padding:8px;">
    </div>
  </div>

  <div id="separator"></div>
  
  <div class="scan-fields">
    <input id="screen-scan" autofocus placeholder="Scan screen mac here" />
    <input id="physical-scan" autofocus placeholder="Scan physical mac here" />
  </div>

  <div id="separator"></div>
  <div id="last-scan">Last scan:</div>

  <div id="history-box" style="margin: 30px auto 0; width: 700px; max-width: 90%; text-align: left; background: #ddd; border-radius: 12px; padding: 20px; box-sizing: border-box;">
    <h3 style="margin-top: 0;">Last 10 Scanned Tags</h3>
    <ul id="history-list" style="margin: 0; padding-left: 22px;">
      <li>Loading...</li>
    </ul>
  </div>

  <div class="help-tooltip">
    Help
    <span class="tooltip-text">
      Please sign in with your name on the top.<br>

      Single Scan Mode: Scan one <span style="font-weight: bolder;">MAC</span> and submit.<br><br>
      Double Scan Mode: Scan first <span style="font-weight: bolder;">MAC</span> which is on screen, then second matching <span style="font-weight: bolder;">MAC</span> on the tag itself.<br><br>
      
      If they are the same, then the program will check to see if it exists in the database.
      If not, it will say <span style="color: green;">GOOD</span> and write that <span style="font-weight: bolder;">MAC</span> to the database.<br><br>

      If they are the same but that <span style="font-weight: bolder;">MAC</span> exists in the database because it matches, then it will say <span style="color: red;">BAD</span>. Please separate those tags into another bin.<br><br>

      If the Screen <span style="font-weight: bolder;">MAC</span> and Physical <span style="font-weight: bolder;">MAC</span> do NOT match, then the program will say that there is a <span style="color: red;">MISMATCH</span>. Please separate those tags into another bin.<br><br>

      The history box will give you the last 10 scanned tags by you. 
    </span>
  </div>

  <div id="result">READY</div>

  <script>
    const screenInput = document.getElementById('screen-scan');
    const physicalInput = document.getElementById('physical-scan');
    const resultDiv = document.getElementById('result');
    const lastScanDiv = document.getElementById('last-scan');
    const historyList = document.getElementById('history-list');
    const workerInput = document.getElementById('workerName');
    const successSound = document.getElementById("successSound");
    const errorSound = document.getElementById("errorSound");
    const successSuccessSound = document.getElementById("successSuccessSound");
    const doubleModeToggle = document.getElementById('doubleModeToggle');
    const validationModeToggle = document.getElementById('validationModeToggle');

    function playSuccessSound() {
      successSound.currentTime = 0;
      successSound.play().catch(() => {});
    }

    function playErrorSound() {
      errorSound.currentTime = 0;
      errorSound.play().catch(() => {});
    }

    function playSuccessSuccessSound() {
      successSuccessSound.currentTime = 0;
      successSuccessSound.play().catch(() => {});
    }

    function updateScanMode() {
      if (doubleModeToggle.checked) {
        physicalInput.style.display = 'block';
        physicalInput.placeholder = 'Scan Physical MAC here';
        screenInput.placeholder = 'Scan Screen MAC here';
      } else {
        physicalInput.style.display = 'none';
        screenInput.placeholder = 'Scan MAC here';
      }
    }

    function isValidMac(code) {
      return code.length === 12;
    }

    function processSingleScan() {
      const code = normalizeMac(screenInput.value);
      const worker = workerInput.value.trim();

      if (!code) return;

      fetch('/scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:
          'code=' + encodeURIComponent(code) +
          '&worker=' + encodeURIComponent(worker)
      })
        .then(res => res.json())
        .then(data => {
          lastScanDiv.textContent = 'Last scan: ' + code;
          resultDiv.textContent = data.result;
          resultDiv.className = data.result === 'GOOD' ? 'good' : 'bad';

          if (data.result === 'GOOD') {
            playSuccessSuccessSound();
          } else {
            playErrorSound();
          }

          loadHistory();
          resetScanInputs();
        })
        .catch((err) => {
          console.error('SCAN ERROR:', err);
          resultDiv.textContent = 'ERROR';
          resultDiv.className = 'bad';
          playErrorSound();
          resetScanInputs();
        });
    }

    doubleModeToggle.addEventListener('change', updateScanMode);
    updateScanMode();

    workerInput.value = localStorage.getItem('workerName') || '';    

    workerInput.addEventListener('change', () => {
      localStorage.setItem('workerName', workerInput.value.trim());
      loadHistory();
    });

    function renderHistory(items) {
      if (!items.length) {
        historyList.innerHTML = '<li>No scans yet</li>';
        return;
      }

      historyList.innerHTML = items.map(item => {
        const isGood = item.result === 'GOOD';
        let extraMessage = item.reason;

        if (item.reason === 'ALREADY_SCANNED') {
          const who = item.last_scanned_by || 'Unknown';
          const when = item.last_scanned_at || 'Unknown time';
          extraMessage = `Already scanned by ${who} at ${when}`;
        } else if (item.reason === 'IMPORTED_LIST') {
          extraMessage = 'Exists in Master MAC list';
        } else if (item.reason === 'ACCEPTED') {
          extraMessage = 'Accepted';
        }

        return `
          <li style="margin-bottom: 8px;">
            <span>${item.mac}</span>
            -
            <strong style="color:${isGood ? 'green' : 'red'};">
              ${item.result}
            </strong>
            <span style="color:#555;">
              (${extraMessage})
            </span>
          </li>
        `;
      }).join('');
    }

    function loadHistory() {
      const worker = workerInput.value.trim();

      if (!worker) {
        historyList.innerHTML = '<li>Enter your name to load history</li>';
        return;
      }

      fetch('/history?worker=' + encodeURIComponent(worker))
        .then(res => res.json())
        .then(data => renderHistory(data))
        .catch((err) => {
          console.error('HISTORY ERROR:', err);
          historyList.innerHTML = '<li>Could not load history</li>';
        });
    }

    
    function normalizeMac(value) {
      return value.replace(/[^a-zA-Z0-9]/g, "").toUpperCase().trim();
    }

    function resetScanInputs() {
      screenInput.value = '';
      physicalInput.value = '';
      screenInput.focus();
    }

    function processMatchedScan() {
      const screenCode = normalizeMac(screenInput.value);
      const physicalCode = normalizeMac(physicalInput.value);
      const worker = workerInput.value.trim();

      if (validationModeToggle.checked && !isValidMac(physicalCode)) {
          lastScanDiv.textContent = 'Last scan: ' + physicalCode;
          resultDiv.textContent = 'PHYSICAL MAC: INVALID LENGTH';
          resultDiv.className = 'bad';
          playErrorSound();
          resetScanInputs();
          return; 
      }

      if (!screenCode || !physicalCode) return;

      if (screenCode !== physicalCode) {
        lastScanDiv.textContent = 'Last scan: ' + screenCode + ' / ' + physicalCode;
        resultDiv.textContent = 'MISMATCH';
        resultDiv.className = 'bad';
        playErrorSound();
        resetScanInputs();
        return;
      }

      fetch('/scan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:
          'code=' + encodeURIComponent(screenCode) +
          '&worker=' + encodeURIComponent(worker)
      })
        .then(res => res.json())
        .then(data => {
          lastScanDiv.textContent = 'Last scan: ' + screenCode;
          resultDiv.textContent = data.result;
          resultDiv.className = data.result === 'GOOD' ? 'good' : 'bad';

          if (data.result === 'GOOD') {
            playSuccessSuccessSound();
          } else {
            playErrorSound();
          }

          loadHistory();
          resetScanInputs();
        })
        .catch((err) => {
          console.error('SCAN ERROR:', err);
          resultDiv.textContent = 'ERROR';
          resultDiv.className = 'bad';
          playErrorSound();
          resetScanInputs();
        });
  }

  screenInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();

      if (doubleModeToggle.checked) {
        const firstCode = normalizeMac(screenInput.value);

        if (!firstCode) return;
        
        if (validationModeToggle.checked && !isValidMac(firstCode)) {
          lastScanDiv.textContent = 'Last scan: ' + firstCode;
          resultDiv.textContent = 'SCREEN MAC: INVALID LENGTH';
          resultDiv.className = 'bad';
          playErrorSound();
          resetScanInputs();
          return; 
        }        

        resultDiv.innerHTML = `
          <div>1ST SCAN RECORDED</div>
          <div style="font-size:26px; margin-top:12px;">Awaiting 2nd scan...</div>
        `;
        resultDiv.className = 'pending';

        playSuccessSound();
        physicalInput.focus();
      } else {
        processSingleScan();
      }
    }
  });

  physicalInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      processMatchedScan();
    }
  });

  loadHistory();
  </script>

</body>
</html>